[package]
name = "APEX"
version = "0.1.0"
edition = "2024"
build = "build.rs"

[profile.release]
opt-level = 3
lto = "fat"
codegen-units = 1
debug = false
panic = "abort"
strip = true

[dependencies]
slint = "1"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
webbrowser = "0.8"
plotters = { version = "0.3", default-features = false, features = ["bitmap_backend", "bitmap_encoder", "line_series", "point_series", "ttf"] }
anyhow = "1.0.98"
ndarray = "0.16.1"
ort = { version = "2.0.0-rc.10", features = ["directml"] }
image = "0.25.6"
num_cpus = "1.17.0"
serialport = "4.7.2"
sdl2 = { version = "0.34", features = ["bundled"] }
vigem_client = { package = "vigem-client", version = "0.1.4" }
windows = { version = "0.48.0", features = [
    "Win32_Devices_DeviceAndDriverInstallation",
    "Win32_Devices_HumanInterfaceDevice",
    "Win32_Foundation",
    "Win32_Graphics_Gdi",
    "Win32_System_Registry",
    "Win32_UI_Input_KeyboardAndMouse",
    "Win32_UI_WindowsAndMessaging",
] }
windows-capture = "1.5.0"

[build-dependencies]
slint-build = "1"
